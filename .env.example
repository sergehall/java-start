APP_ENV=production
COMPOSE_PROJECT_NAME=java-start-prod

POSTGRES_DB=java_start_prod
POSTGRES_USER=java_start
POSTGRES_PASSWORD=replace-me
POSTGRES_PORT=5433
POSTGRES_VOLUME=java-start-prod-postgres-data

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/java_start_prod
SPRING_DATASOURCE_USERNAME=java_start
SPRING_DATASOURCE_PASSWORD=replace-me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
APP_SECURITY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_SECURITY_JWT_SECRET=replace-this-production-jwt-secret-with-at-least-32-characters
APP_SECURITY_TOKEN_TTL=7d

MAIL_PROVIDER=smtp
MAIL_FROM=no-reply@example.com
SMTP_FROM_EMAIL=no-reply@example.com
MAIL_SUPPORT=support@example.com
AUTH_EMAIL_VERIFICATION_TTL_SECONDS=900
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USERNAME=replace-with-smtp-user
SMTP_APP_PASSWORD=
SMTP_PASSWORD=replace-with-smtp-password

BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=production
