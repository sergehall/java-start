APP_ENV=local
COMPOSE_PROJECT_NAME=java-start-local

POSTGRES_DB=java_start_local
POSTGRES_USER=java_start
POSTGRES_PASSWORD=java_start_local_password
POSTGRES_PORT=5432
POSTGRES_VOLUME=java-start-local-postgres-data

SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/java_start_local
SPRING_DATASOURCE_USERNAME=java_start
SPRING_DATASOURCE_PASSWORD=java_start_local_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
APP_SECURITY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_SECURITY_JWT_SECRET=local-development-jwt-secret-change-before-production-0001
APP_SECURITY_TOKEN_TTL=7d

BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local
